// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User{
  id Int @id @default(autoincrement())

  nome String
  email String @unique
  Pass String

  idade Int?
  cpf String? @unique
  createdAt DateTime @default(now())

  company Company? @relation(fields:[companyId],references: [id])   
  companyId Int?

  taskCriada Tasks[] @relation("tarefaPassada")
  taskRecebida Tasks[] @relation("tarefaRecebida")
  chatP ChatParticipant[]//um user pode ter varios chats
  message Message[]//um user pode ter varias mensagens
  logs Logs[]

  role Role @default(USER)
  status UserStatus @default(PENDENTE)
}

model Company{
  id Int @id @default(autoincrement())
  nome String
  cnpj String @unique
  telefone String @unique
  email String @unique
  endereco String
  createdAt DateTime @default(now())
  ownerId Int 

  user User[]//uma empresa pode ter vários usuários
  chat Chat[]//uma empresa pode ter vários chats
  tasks Tasks[]
}
model ChatParticipant{
  id Int @id @default(autoincrement())
  joinedAt DateTime @default(now())

  chat Chat @relation(fields: [chatId],references: [id])//um chat pode ter varios participantes
  chatId Int

  user User @relation(fields: [userId],references: [id])//um participante pode ter varios chats
  userId Int

  @@unique([chatId,userId])
}

model Chat{
  id Int @id @default(autoincrement())
  nome String @unique
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId],references: [id])//uma empresa pode ter varios chats
  companyId Int 

  chatparticipant ChatParticipant[]//um chat pode conter varios participantes
  message Message[]//um chat tem varias mensages
  tipo Tipo
  tasks Tasks[]
}


model Message{
  id Int @id @default(autoincrement())
  content String
  createdAt DateTime @default(now())  
  
  user User @relation(fields: [userId],references: [id])//um usuario pode ter varias mensages
  userId Int

  chat Chat @relation(fields: [chatId],references: [id])//um chat pode ter varias mensagens
  chatId Int
}


model Tasks{
  id Int @id @default(autoincrement())
  
  company Company @relation(fields: [companyId],references: [id])
  companyId Int

  autor User @relation("tarefaPassada",fields: [autorId],references: [id])
  autorId Int

  atarefado User? @relation("tarefaRecebida", fields: [atarefadoId],references: [id])
  atarefadoId Int?

  chat Chat @relation(fields: [chatId],references: [id])
  chatId Int

  task String
  status String
  createdAt DateTime @default(now())
  dateLimit DateTime?
}


model Logs{
  id Int @id @default(autoincrement())
  dateTime DateTime @default(now())
  action String
  metaData Json?

  user User @relation(fields: [userId],references: [id])
  userId Int
}


enum Role {
  USER
  ADMIN
  SUPERUSER
  CEO
}

enum Tipo {
  DIRECT
  GROUP
}

enum TaskStatus {
  A_FAZER        
  ABERTA         // O seu "SEMATAREFADO" - disponível no grupo para alguém pegar
  EM_REVISAO     // O colaborador entregou, aguardando aprovação do chefe
  CONCLUIDO      // Finalizada com sucesso
  ATRASADO       // Sistema detectou que passou do dateLimit (Lógica de backend)
  CANCELADO      // Tarefa descartada
}

enum UserStatus {
  PENDENTE
  APROVADO
  NEGADO
}